---
import Base from "../layouts/Base.astro";
import CompareSection from "../components/CompareSection";
import { uptimeScores, PROVIDER_META, getProviderIncidents } from "../lib/data";

const scores = uptimeScores.providers;

function buildProviderData(provider: "aws" | "azure" | "gcp") {
  const incidents = getProviderIncidents(provider);
  const dates = incidents.map(i => new Date(i.startedAt).getTime()).sort((a, b) => a - b);
  return {
    incidents: incidents.map(i => ({ startedAt: i.startedAt, durationMinutes: i.durationMinutes })),
    coverage: {
      count: incidents.length,
      earliest: dates.length > 0 ? new Date(dates[0]).toISOString().slice(0, 10) : null,
      source: provider === "aws"
        ? "AWS Health API + S3 history"
        : provider === "azure"
        ? "Azure PIRs (Post-Incident Reviews)"
        : "GCP product history pages (204 products)",
    },
  };
}

const awsData = buildProviderData("aws");
const azureData = buildProviderData("azure");
const gcpData = buildProviderData("gcp");

const incidentsByProvider = {
  aws: awsData.incidents,
  azure: azureData.incidents,
  gcp: gcpData.incidents,
};

const coverageByProvider = {
  aws: awsData.coverage,
  azure: azureData.coverage,
  gcp: gcpData.coverage,
};
---

<Base title="Compare Providers">
  <h1 class="page-title">Cross-Provider Comparison</h1>
  <CompareSection client:load scores={scores} providerMeta={PROVIDER_META} incidentsByProvider={incidentsByProvider} coverageByProvider={coverageByProvider} />
</Base>

<style>
  .page-title { font-size: 1.5rem; margin-bottom: 1.5rem; }
</style>
